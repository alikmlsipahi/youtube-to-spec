# feature-requirement-extractor — OpenAI engine configuration.
#
# Copy this file to `.env` (in the directory you run the script from) and fill in
# your key. `.env` is gitignored; NEVER commit real secrets. The Claude-native
# engine (the default) needs none of this.

# Required for `--engine openai`.
OPENAI_API_KEY=your_key_here

# Optional overrides. Precedence: CLI flag > env var > built-in default.
# Values shown are the built-in defaults.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.2
# OPENAI_MAX_TOKENS=4096
# OPENAI_RESPONSE_FORMAT=json_schema
# OPENAI_TIMEOUT=60
# OPENAI_RETRIES=3
# OPENAI_CONCURRENCY=4
